# ─── Lemma API ───────────────────────────────────────────────────────────────
# On Vercel, set NEXT_PUBLIC_LEMMA_API_URL to your deployed URL:
# https://your-app.vercel.app/api/lemma
# On localhost, keep as-is (proxy runs locally).
NEXT_PUBLIC_LEMMA_API_URL=http://localhost:3000/api/lemma

NEXT_PUBLIC_LEMMA_AUTH_URL=https://auth.lemma.work
NEXT_PUBLIC_LEMMA_POD_ID=your-pod-id-here

# ─── Auth Token ──────────────────────────────────────────────────────────────
# Get via: lemma auth print-token
# On Vercel: set this in the Vercel dashboard under Settings > Environment Variables.
# Note: tokens expire every ~60 minutes. For production, set up a service account
# or periodically redeploy to refresh.
NEXT_PUBLIC_LEMMA_TOKEN=your-lemma-token-here
LEMMA_TOKEN=your-lemma-token-here

# ─── Local Dev Only ──────────────────────────────────────────────────────────
# Not needed / not used on Vercel (no CLI available in serverless).
# Remove or leave blank when deploying.
LEMMA_BIN=C:\Users\you\.local\bin\lemma.exe
